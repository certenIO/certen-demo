# ─────────────────────────────────────────────────────────────────────────────
# Certen Demos — environment
# Copy to .env. Everything runs in DEMO_MODE=simulated out of the box (zero deps).
# Flip to DEMO_MODE=live to drive the real API Gateway.
# ─────────────────────────────────────────────────────────────────────────────

# simulated = fully self-contained, no external services needed (default, always works)
# live      = orchestrator calls the real API Gateway / proofs service
DEMO_MODE=simulated

# Orchestrator
ORCHESTRATOR_PORT=8770

# Cockpit -> Orchestrator (used by the Vite dev server / build)
VITE_ORCHESTRATOR_URL=http://127.0.0.1:8770

# ── Live mode wiring (only used when DEMO_MODE=live) ──────────────────────────
# Defaults point at the healthy live stack; set GATEWAY_API_KEY to run the real Kermit
# authorization path (npm --workspace orchestrator run kermit:check). EVM execution below
# is already real without a gateway key.
GATEWAY_URL=https://gateway.kompendium.co
GATEWAY_API_KEY=
PROOFS_URL=https://proofs.kompendium.co
# Block explorers used to build "verify on-chain" links
EXPLORER_BASE_SEPOLIA=https://sepolia.basescan.org
EXPLORER_ARBITRUM_SEPOLIA=https://sepolia.arbiscan.io

# ── Real EVM execution (live mode) ────────────────────────────────────────────
# The sponsor key MUST equal the demo contracts' authorizer (see contracts/deployments.json).
# For the existing deployment use api-bridge/.env EVM_SPONSOR_PRIVATE_KEY (0x3242…185FC8).
EVM_SPONSOR_PRIVATE_KEY=
# RPCs default to the public endpoints below if unset (Alchemy works too, if under quota).
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ── Demo 2 AI agent (only used by the agent harness) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-replace-me
AGENT_MODEL=claude-opus-4-8
